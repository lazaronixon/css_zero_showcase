<div class="command" style="--dialog-size: 24rem" data-controller="command" data-action="combobox-commit->command#commit">
  <label class="command__input input input--actor flex items-center gap">
    <span class="icon icon--search" aria-hidden="true"></span>
    <%= text_field_tag "search", nil, data: { command_target: "input", action: "command#filter" }, autocomplete: "off", placeholder: "Type a command or search..." %>
  </label>
  <div class="command__list" data-command-target="list" role="listbox" aria-label="Commands">
    <%= render "command_options" %>
  </div>
</div>
