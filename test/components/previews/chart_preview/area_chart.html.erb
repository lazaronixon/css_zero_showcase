<% @chart_data = {
  labels: [ "January", "February", "March", "April", "May", "June", "July" ],
  datasets: [
    { label: "Dataset 1", backgroundColor: "#8ec5ff80", borderColor: "#8ec5ff", fill: true, data: [65, 59, 80, 81, 56, 55, 40] },
    { label: "Dataset 2", backgroundColor: "#2b7fff80", borderColor: "#2b7fff", fill: true, data: [35, 40, 55, 60, 36, 25, 20] }
  ]
} %>

<div class="relative i-full" style="block-size: 400px;">
  <%= tag.canvas aria: { label: "Example" }, role: "img", data: { controller: "chart", chart_type_value: "line", chart_data_value: @chart_data.to_json } %>
</div>
