<% @chart_data = {
  labels: [ "January", "February", "March", "April", "May", "June" ],
  datasets: [
    { label: "Desktop", backgroundColor: "#8ec5ff80", borderColor: "#8ec5ff", data: [186, 305, 237, 273, 209, 214] }
  ]
} %>

<% @chart_options = { scales: {
  r: { border: { display: false }, grid: { tickLength: 0 }, ticks: { display: false, maxTicksLimit: 5 } }
} } %>

<div class="relative i-full" style="block-size: 400px;">
  <%= tag.canvas aria: { label: "Example" }, role: "img", data: { controller: "chart", chart_type_value: "radar", chart_data_value: @chart_data.to_json, chart_options_value: @chart_options.to_json } %>
</div>
