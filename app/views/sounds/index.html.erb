<% if flash[:notice] %>
  <div popover="manual" class="flash" data-controller="flash sound" data-action="animationend->flash#hide" data-sound-connect-value="success" role="alert">
    <div class="flash__content flex items-center gap">
      <span class="icon icon--circle-check" style="--icon-size: 1.25rem" aria-hidden="true"></span>
      <span class="font-medium"><%= flash[:notice] %></span>
    </div>
  </div>
<% end %>

<% if flash[:alert] %>
  <div popover="manual" class="flash" data-controller="flash sound" data-action="animationend->flash#hide" data-sound-connect-value="error" role="alert">
    <div class="flash__content flex items-center gap">
      <span class="icon icon--circle-alert" style="--icon-size: 1.25rem" aria-hidden="true"></span>
      <span class="font-medium"><%= flash[:alert] %></span>
    </div>
  </div>
<% end %>

<div class="container flex flex-col justify-center gap p-4" style="row-gap: 2.5rem; --container-width: 28rem">
  <div class="flex flex-col">
    <h2 class="text-2xl font-bold">Sound feedback</h2>
    <p class="text-subtle">Add subtle audio cues to interactions like clicks, toggles, and form submissions.</p>
  </div>

  <div class="flex flex-wrap items-center gap">
    <%= button_to tag.span("Success"), main_app.success_sounds_path, class: "btn btn--busy btn--feedback", "data-action": "sound#loading" %>
    <%= button_to tag.span("Failure"), main_app.failure_sounds_path, class: "btn btn--busy btn--feedback", "data-action": "sound#loading" %>
    <%= button_tag "Tactile", type: "button", class: "btn btn--feedback", "data-action": "pointerdown->sound#press pointerup->sound#release" %>

    <label class="btn btn--toggle btn--feedback">
      <%= check_box_tag :btn_toggle, "data-action": "sound#toggle" %><span>Toggle</span>
    </label>

    <div contents>
      <button type="button" class="btn btn--feedback" data-action="pointerdown->sound#press pointerup->sound#release" popovertarget="dropdown" aria-haspopup="true">
        Dropdown
      </button>

      <div popover id="dropdown" class="popover popover--block-end-start"  style="--popover-size: 8rem;" role="menu" aria-label="Menu">
        <div class="menu" data-controller="menu" data-action="keydown->menu#navigate keydown->sound#tick">
          <%= link_to "Edit", "#", class: "btn menu__item", data: { menu_target: "item", action: "mouseenter->sound#tick" }, role: "menuitem" %>
          <%= link_to "Make a copy", "#", class: "btn menu__item", data: { menu_target: "item", action: "mouseenter->sound#tick" }, role: "menuitem" %>
          <%= link_to "Favorite", "#", class: "btn menu__item", data: { menu_target: "item", action: "mouseenter->sound#tick" }, role: "menuitem" %>
          <hr class="menu__separator" role="separator"/>
          <%= link_to "Classify", "#", class: "btn menu__item", data: { menu_target: "item", action: "mouseenter->sound#tick" }, role: "menuitem" %>
          <hr class="menu__separator" role="separator"/>
          <%= link_to "Delete", "#", class: "btn menu__item", data: { menu_target: "item", action: "mouseenter->sound#tick" }, role: "menuitem" %>
        </div>
      </div>
    </div>

    <div contents data-controller="dialog">
      <button type="button" class="btn btn--feedback" data-action="dialog#showModal sound#bloom">
        Sheet
      </button>

      <dialog class="sheet sheet--left" data-dialog-target="content" data-action="click->dialog#closeOnClickOutside close->sound#droplet" aria-label="Edit profile">
        <button type="button" class="btn btn--plain sheet__close" data-action="dialog#close">
          <span class="icon icon--x" aria-hidden="true"></span>
          <span class="sr-only">Close</span>
        </button>
        <div class="sheet__content">
          <%= render "lookbook/preview/profile_form" %>
        </div>
      </dialog>
    </div>

    <div contents data-controller="dialog">
      <button type="button" class="btn btn--feedback" data-action="dialog#showModal sound#bloom">
        Dialog
      </button>

      <dialog class="dialog" style="--dialog-size: 24rem;" data-dialog-target="content" data-action="close->sound#droplet" role="alertdialog" aria-labelledby="dialog_label" aria-describedby="dialog_desc">
        <div class="dialog__content">
          <h2 class="font-medium leading-none mbe-2" id="dialog_label">Are you absolutely sure?</h2>
          <p class="text-sm text-balance text-subtle mbe-4" id="dialog_desc">
            This action cannot be undone. This will permanently delete your account and remove your data from our servers.
          </p>

          <div class="flex items-center justify-end gap">
            <button type="button" class="btn" data-action="dialog#close">Cancel</button>
            <button type="button" class="btn btn--primary">Continue</button>
          </div>
        </div>
      </dialog>
    </div>
  </div>

  <nav class="breadcrumb" aria-label="Breadcrumb">
    <%= link_to "Home", "#", "data-action": "mouseenter->sound#tick" %>
    <span class="icon icon--chevron-right" aria-hidden="true"></span>
    <%= link_to "Layouts", "#", "data-action": "mouseenter->sound#tick" %>
    <span class="icon icon--chevron-right" aria-hidden="true"></span>
    <%= link_to "Components", "#", "data-action": "mouseenter->sound#tick" %>
    <span class="icon icon--chevron-right" aria-hidden="true"></span>
    <span class="text-primary" aria-disabled="true" aria-current="page" role="link">Breadcrumb</span>
  </nav>

  <%= range_field_tag "range_field", 2, min: 0, max: 10, class: "input i-full", "data-action": "sound#tick" %>

  <fieldset class="flex align-center" style="column-gap: 1rem">
    <div class="flex items-center gap-half">
      <%= radio_button_tag :setting, :default, class: "input", "data-action": "sound#toggle" %>
      <%= label_tag :setting_default, "Default", class: "text-sm font-medium" %>
    </div>
    <div class="flex items-center gap-half">
      <%= radio_button_tag :setting, :comfortable, 1, class: "input", "data-action": "sound#toggle" %>
      <%= label_tag :setting_comfortable, "Comfortable", class: "text-sm font-medium" %>
    </div>
    <div class="flex items-center gap-half">
      <%= radio_button_tag :setting, :compact, class: "input", "data-action": "sound#toggle" %>
      <%= label_tag :setting_compact, "Compact", class: "text-sm font-medium" %>
    </div>
  </fieldset>

  <div class="flex items-center gap">
    <%= check_box_tag :status, checked: true, class: "switch", role: "switch", "data-action": "sound#toggle" %>
    <%= label_tag :status, "Airplane Mode", class: "text-sm font-medium" %>
  </div>

  <%= select_tag :fruits, options_for_select(["Apple", "Banana", "Blueberry", "Grapes", "Pineaple"]), class: "input", "data-action": "sound#toggle" %>

  <%= text_field_tag :tags, "awesome,neat", autocomplete: "off", placeholder: "How cool is this?", data: { controller: "combobox", action: "sound#toggle" } %>

  <%= text_field_tag :default_datepicker, nil, placeholder: "Pick a date", class: "input", data: { controller: "datepicker", action: "sound#toggle" } %>

  <div class="input input--actor input--copyable flex items-center gap" data-controller="input-copyable">
    <%= text_field_tag "input_copyable", SecureRandom.base58(32), readonly: "readonly", data: { input_copyable_target: "input" } %>
    <button type="button" class="btn btn--plain" data-action="input-copyable#copy sound#sparkle">
      <span class="icon icon--copy" aria-hidden="true"></span>
      <span class="sr-only">Copy to clipboard</span>
    </button>
  </div>

  <div class="input input--actor input--revealable flex items-center gap" data-controller="input-revealable">
    <%= password_field_tag "input_revealable", "DefinitelyNot123", data: { input_revealable_target: "input" } %>
    <button type="button" class="btn btn--plain" data-action="input-revealable#reveal sound#toggle">
      <span class="icon" aria-hidden="true"></span>
      <span class="sr-only">Toggle password visibility</span>
    </button>
  </div>

  <div class="input input--clearable input--actor flex items-center gap" data-controller="input-clearable">
    <%= search_field_tag "input_clearable", "DefinitelyNot123", placeholder: "Type something", data: { input_clearable_target: "input" } %>
    <button type="button" class="btn btn--plain" data-action="input-clearable#clear sound#whisper">
      <span class="icon icon--x" aria-hidden="true"></span>
      <span class="sr-only">Clear input</span>
    </button>
  </div>

  <%= form_with url: nil, class: "flex justify-center", data: { controller: "form", action: "submit->sound#success" } do |form| %>
    <%= form.text_field :code, placeholder: "••••••", autocorrect: "off", autocapitalize: "none", spellcheck: false, autocomplete: "one-time-code", maxlength: 6, class: "input input--otp", style: "--input-otp-size: 18ch", data: { action: "paste->form#submit sound#tick", "1p-ignore": true } %>
  <% end %>

  <div class="carousel" data-controller="carousel" data-action="keydown.left->carousel#prev keydown.right->carousel#next keydown->sound#page" role="region" aria-roledescription="carousel">
    <button type="button" class="btn btn--icon" data-action="carousel#prev sound#page">
      <span class="icon icon--chevron-left" aria-hidden="true"></span>
      <span class="sr-only">Previous slide</span>
    </button>

    <div class="carousel__content" data-carousel-target="content" tabindex="-1">
      <div class="carousel__item">
        <div class="card flex items-center justify-center aspect-square" role="group" aria-roledescription="slide">
          <span class="text-4xl leading-none font-semibold">1</span>
        </div>
      </div>
      <div class="carousel__item">
        <div class="card flex items-center justify-center aspect-square" role="group" aria-roledescription="slide">
          <span class="text-4xl leading-none font-semibold">2</span>
        </div>
      </div>
      <div class="carousel__item">
        <div class="card flex items-center justify-center aspect-square" role="group" aria-roledescription="slide">
          <span class="text-4xl leading-none font-semibold">3</span>
        </div>
      </div>
    </div>

    <button type="button" class="btn btn--icon" data-action="carousel#next sound#page">
      <span class="icon icon--chevron-right" aria-hidden="true"></span>
      <span class="sr-only">Next slide</span>
    </button>
  </div>

  <nav class="pagination justify-center" aria-label="Pagination">
    <%= link_to "#", class: "btn pagination__button", "data-action": "sound#page", aria: { label: "Previous page" } do %>
      <span class="icon icon--chevron-left" aria-hidden="true"></span>
      <span>Previous</span>
    <% end %>

    <%= link_to "1", "#", class: "btn pagination__button", "data-action": "sound#page" %>
    <%= link_to "2", "#", class: "btn pagination__button", "data-action": "sound#page", aria: { current: "page" } %>
    <%= link_to "3", "#", class: "btn pagination__button", "data-action": "sound#page" %>

    <div class="inline-flex items-center pi-2" aria-hidden="true">
      <span class="icon icon--ellipsis"></span>
    </div>

    <%= link_to "#", class: "btn pagination__button", "data-action": "sound#page", aria: { label: "Next page" } do %>
      <span>Next</span>
      <span class="icon icon--chevron-right" aria-hidden="true"></span>
    <% end %>
  </nav>

  <div class="accordion">
    <details name="my_accordion">
      <summary data-action="click->sound#toggle">How do I reset my password?</summary>
      <p class="pbe-4">
        Click on 'Forgot Password' on the login page, enter your email address, and we'll send you a link to reset your password. The link will expire in 24 hours.
      </p>
    </details>
    <details name="my_accordion">
      <summary data-action="click->sound#toggle">Can I change my subscription plan?</summary>
      <p class="pbe-4">
        Yes, you can upgrade or downgrade your plan at any time from your account settings. Changes will be reflected in your next billing cycle.
      </p>
    </details>
    <details name="my_accordion">
      <summary data-action="click->sound#toggle">What payment methods do you accept?</summary>
      <p class="pbe-4">
        We accept all major credit cards, PayPal, and bank transfers. All payments are processed securely through our payment partners.
      </p>
    </details>
  </div>

  <div class="tabs" data-controller="tabs">
    <div class="tabs__list" data-action="keydown.left->tabs#prev keydown.right->tabs#next" role="tablist">
      <button type="button" id="trigger_account"  class="btn tabs__button" data-tabs-target="button" data-action="tabs#select sound#toggle" role="tab" aria-controls="tab_account">Account</button>
      <button type="button" id="trigger_password" class="btn tabs__button" data-tabs-target="button" data-action="tabs#select sound#toggle" role="tab" aria-controls="tab_password">Password</button>
    </div>

    <div hidden id="tab_account" data-tabs-target="tab" role="tabpanel" aria-labelledby="trigger_account">
      <%= render "lookbook/preview/account_form" %>
    </div>

    <div hidden id="tab_password" data-tabs-target="tab" role="tabpanel" aria-labelledby="trigger_password">
      <%= render "lookbook/preview/password_form" %>
    </div>
  </div>
</div>
